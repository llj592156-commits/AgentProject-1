
# OpenAI API Key (required for LLM functionality)
OPENAI_API_KEY=your_openai_api_key_here

# Turkish Airlines MCP Configuration
# Path to Node.js binary directory (default: /usr/local/bin)
# Example for NVM users: /Users/yourusername/.nvm/versions/node/v22.19.0/bin
NODE_BIN_PATH=/usr/local/bin

# MCP Remote command (default: mcp-remote)
# If installed globally: mcp-remote
# If using npx: npx mcp-remote
MCP_REMOTE_COMMAND=mcp-remote